function updateSummary(){const method=$('#method').value;const url=$('#url').value.trim();const source=$('#request-mode').value;const engine=$('input[name=engineMode]:checked').value;$('#summary-method').textContent=method;$('#summary-url').textContent=url||'Not configured';$('#summary-source').textContent=source==='builder'?'Builder':source==='raw'?'Raw HTTP':'cURL';$('#engine-status').textContent=engine==='browser'?'JavaScript browser':'HTTP';$('#summary-output').textContent=$('input[name=saveOutput]').checked?'Saved artifact':'Console';$$('.browser-only').forEach(el=>el.classList.toggle('hidden',engine!=='browser'));const bodyDisabled=engine==='browser';$('#body-mode').disabled=bodyDisabled;if(bodyDisabled&&method!=='GET'){$('#method').value='GET';$('#summary-method').textContent='GET'}}
