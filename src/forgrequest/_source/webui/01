.diff-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}.diff-grid textarea{min-height:260px}.feature-list{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px}.feature{border:1px solid var(--line);background:#071421;border-radius:13px;padding:12px}.feature strong{display:block;font-size:12px}.feature span{display:block;margin-top:5px;color:var(--muted);font-size:10.5px;line-height:1.45}
