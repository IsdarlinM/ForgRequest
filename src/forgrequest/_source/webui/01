.mode-switch{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:9px}.mode-option{position:relative}.mode-option input{position:absolute;opacity:0;pointer-events:none}.mode-card{display:block;border:1px solid var(--line);background:#071422;border-radius:14px;padding:13px;cursor:pointer;min-height:83px}.mode-card strong{display:block;font-size:13px}.mode-card span{display:block;color:var(--muted);font-size:10.5px;line-height:1.45;margin-top:5px}.mode-option input:checked+.mode-card{border-color:var(--accent);background:rgba(56,215,208,.10);box-shadow:0 0 0 3px rgba(56,215,208,.07)}
