label.field-label{display:block;color:var(--muted);font-size:10px;font-weight:880;letter-spacing:.08em;text-transform:uppercase;margin:0 0 7px}input:not([type=checkbox]),select,textarea{display:block;width:100%;max-width:100%;min-width:0;border:1px solid #29445f;background:#061321;color:var(--text);border-radius:12px;padding:11px 12px;outline:none;font-size:13px}input:not([type=checkbox]),select{height:44px}textarea{min-height:132px;resize:vertical;font:12.5px/1.48 ui-monospace,SFMono-Regular,Consolas,monospace}input:focus,select:focus,textarea:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(56,215,208,.1)}input:disabled,select:disabled,textarea:disabled{opacity:.5;cursor:not-allowed}.help-text{margin:7px 0 0;color:var(--muted-2);font-size:10.5px;line-height:1.5}.mono{font-family:ui-monospace,SFMono-Regular,Consolas,monospace;color:#adfff2}
